#!/bin/sh

. $QCOMMON

trap_init

parse_args() {
    local _fn="parse_args" _opts _pos1 _pos2
    while getopts c:hp:svz _opts ; do
        case $_opts in
            c) CELL="$OPTARG" ;;
            h) eval $(WARN list_usage) ; cat $ERR ; exit 0 ;;
            p) PARAM="$OPTARG" ;;
            s) snaps="true" ;;
            v) valid="true" ;;
            z) zfs="true" ;;
            *) exit 1 ;;
        esac
    done ; shift $(( OPTIND - 1 ))
    _pos1="$1" ; _pos2="$2"

    # Be nice to the user and try to parse mix/matched options and positionals
    if [ "$CELL" ] && [ -z "$PARAM" ] ; then
        [ "$_pos1" ] && PARAM=$_pos1

    elif [ "$PARAM" ] && [ -z "$CELL" ] ; then
        [ "$_pos1" ] && CELL=$_pos1

    elif [ -z "$CELL" ] && [ -z "$PARAM" ] ; then
        [ "$_pos1" ] && CELL=$_pos1
        [ "$_pos2" ] && PARAM=$_pos2
    fi

    # Convert lower-case entered PARAM to upper (user-friendly)
    [ "$PARAM" ] && PARAM=$(echo "$PARAM" | tr '[:lower:]' '[:upper:]')
    return 0
}

checks() {
    local _fn="checks" _all_params

    if [ "$snaps" ] || [ "$zfs" ] ; then
        [ -z "$CELL" ] && eval $(THROW 1 missing_cell)
    fi

    if [ "$PARAM" ] ; then
        _all_params="$PARAMS_COMN $PARAMS_JAIL $PARAMS_VM"
        quiet echo_grep "$_all_params" "$PARAM" || eval $(THROW bad_param $PARAM)
    fi
}

retrieve_data() {
    local _fn="data_retrieval" _cells_files _defaults_files

    # Cell retrieval has less work than parameter
    if [ "$CELL" ] ; then
        hush ctx_bootstrap_cell $CELL
        [ "$snaps" ] && query_rootsnaps $R_DSET && query_persistsnaps $P_DSET
        [ "$zfs" ] && query_datasets "$R_DSET $P_DSET"
        return 0
    fi

    # All cells, in a single line
    _cells_files=$(ls -1 $D_CELLS | tr '\n' ' ' | sed "s|^|$D_CELLS/|; s| | $D_CELLS/|g")

    # Define which files should be searched for the defaults
    quiet echo_grep "$PARAMS_JAIL" $PARAM && _defaults_files="$DEF_BASE $DEF_JAIL"
    quiet echo_grep "$PARAMS_VM"   $PARAM && _defaults_files="$DEF_BASE $DEF_VM"
    quiet echo_grep "$PARAMS_COMN" $PARAM && _defaults_files="$DEF_BASE $DEF_JAIL $DEF_VM"

    # Pull the parameters from the defaults first, and then the
    defaults=$(grep -E "^$PARAM=" $_defaults_files \
              | sed -E "s|.*/||" | tr -d '"' | tr '=:' ' ' | sed -E 's/.conf//')
    params=$(grep -E "^$PARAM=" $_cells_files | sed -E "s|.*/||" | tr -d '"' | tr '=:' ' ')
}

write_results() {
    local _fn="write_results" _param _val

    make_tmp RESULTS

    # Writing parameters (no cell) is easier, do them first
    if [ -z "$CELL" ] ; then
        echo "$defaults" >> $RESULTS
        echo "$params"   >> $RESULTS
        return 0
    fi

    #### The existence of $CELL is assumed now ###

    if [ "$PARAM" ] ; then
        # For just a single param, there's room to print the snapshots too
        _param=$(ctx_get $PARAM)
        echo "$CELL $PARAM $_param"                                  >> $RESULTS
        [ "$zfs" ]   && echo "$DATASETS"                             >> $RESULTS
        [ "$snaps" ] && echo "$ROOTSNAPS"        | awk '{print $1}'  >> $RESULTS
        [ "$snaps" ] && echo "$PERSISTSNAPS"     | awk '{print $1}'  >> $RESULTS
    else
        # All PARAMS + SNAPS can be quite long. If [-s], prioritize only snaps.
        if [ "$snaps" ] ; then
            [ "$zfs" ]   && echo "$DATASETS"                         >> $RESULTS
            [ "$snaps" ] && echo "$ROOTSNAPS"    | awk '{print $1}'  >> $RESULTS
            [ "$snaps" ] && echo "$PERSISTSNAPS" | awk '{print $1}'  >> $RESULTS
            return 0
        fi

        # Without PARAM specified and no snaps, assume user wants the full list
        for _param in $PARAMS_TYPE ; do
            _val=$(ctx_get $_param)
            echo "$CELL $_param $_val"  >> $RESULTS
        done
        # There's room to print the zfs datasets too
        [ "$zfs" ] && echo "$DATASETS"  >> $RESULTS
    fi
}

main() {
    local _fn="main"

    parse_args "$@" || eval $(THROW 1)

    checks || eval $(THROW 1)

    retrieve_data

    write_results

    cat $RESULTS | column -t
}

main "$@" || { cat $ERR ; exit 1 ;}

